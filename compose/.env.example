# --- Forward-auth demo overlay (forward-auth/docker-compose.forward-auth.yml) ---
# Only used when the Traefik + whoami overlay is started (make compose-forward-auth-up).
# Traefik fronts whoami on https://${WHOAMI_HOST}; the *.sslip.io wildcard maps to 127.0.0.1.
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8081
WHOAMI_HOST=whoami.127-0-0-1.sslip.io
