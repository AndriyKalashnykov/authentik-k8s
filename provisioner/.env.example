# Authentik Go POC — operator-tunable configuration (source of truth).
# Copy to .env and override as needed: `cp .env.example .env`
# `make run` and `make image-run` load these; main.go falls back to these
# same values when the vars are unset, so the program also works without .env.

# --- Connection ---
# Scheme + host the POC connects to. Docker Compose default below; for the
# k8s LoadBalancer form use AUTHENTIK_HOST=<LB-IP>:443
AUTHENTIK_SCHEME=https
AUTHENTIK_HOST=127.0.0.1:9443

# --- Secrets ---
# Admin API token. MUST match AUTHENTIK_BOOTSTRAP_TOKEN in the deployment
# (k8s/postgresql/authentik-postgresql.yml or compose/.env).
AUTHENTIK_BOOTSTRAP_TOKEN=NoMlxBQuYgfu3j19ygGqhjXenAjrJgOfN5naqmSDBUhdLjYqHKze7yyzY07H
# Password assigned to every created user.
AUTHENTIK_USER_PASSWORD=Authentik01234567890!

# --- Demo org structure ---
# Group/user/token-identifier names are derived from the org name in code
# (e.g. <org>-admins, <org>-admin, <org>-admin-token).
AUTHENTIK_ORG1=org-01
AUTHENTIK_ORG2=org-02

# --- Per-user OAuth token keys the POC assigns ---
AUTHENTIK_ORG1_ADMIN_TOKEN=ZId4CDEtmHbnuxkJH2ehUzHgYeTmOansuCO0JsTTsZnYB1z9N0WoAutpyH4i
AUTHENTIK_ORG1_USER_TOKEN=e3qVF1uGTL5DKjglvMKpDYk60X7s89jnbNh9nPEpFYzSgoOHYDSMi0xxYhYr
AUTHENTIK_ORG2_ADMIN_TOKEN=ZId4CDEtmHbnuxkJH2ehUzHgYeTmOansuCO0JsTTsZnYB1z9N0WoAutpyH4i
AUTHENTIK_ORG2_USER_TOKEN=svkH90FMYlnXPA5JHxePVQkozTjXReT6rsdQ2BXedwI5mtrFYR5mfrunMt4B

# --- Forward-auth demo (opt-in) ---
# When enabled, the POC also creates an Authentik proxy provider (forward_domain
# mode) + application and binds it to the embedded outpost, so Traefik's
# forwardAuth can gate the traefik/whoami app (see compose/forward-auth/).
# Disabled by default; the core POC stays a pure user/group/token demo.
# Set false to skip the (non-idempotent) org/user/token provisioning — e.g. when
# only running the idempotent forward-auth setup against an existing instance.
AUTHENTIK_PROVISION_ORGS=true
AUTHENTIK_FORWARD_AUTH_ENABLED=false
AUTHENTIK_FORWARD_AUTH_PROVIDER_NAME=whoami
AUTHENTIK_FORWARD_AUTH_APP_NAME=whoami
AUTHENTIK_FORWARD_AUTH_APP_SLUG=whoami
# External host Traefik fronts. The 127-0-0-1.sslip.io wildcard resolves
# *.127-0-0-1.sslip.io -> 127.0.0.1 with no /etc/hosts edits.
AUTHENTIK_FORWARD_AUTH_EXTERNAL_HOST=https://whoami.127-0-0-1.sslip.io
# Proxy mode: forward_single (one app, the default) or forward_domain (SSO across
# a domain — only then is COOKIE_DOMAIN used).
AUTHENTIK_FORWARD_AUTH_MODE=forward_single
AUTHENTIK_FORWARD_AUTH_COOKIE_DOMAIN=127-0-0-1.sslip.io
# Stock Authentik flow slugs (PKs are resolved at runtime, never hardcoded).
AUTHENTIK_FORWARD_AUTH_AUTHZ_FLOW=default-provider-authorization-implicit-consent
AUTHENTIK_FORWARD_AUTH_INVALIDATION_FLOW=default-provider-invalidation-flow
